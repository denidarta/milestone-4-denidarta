generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  TRANSFER
  DEPOSIT
  WITHDRAWAL
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  role      UserRole
  accounts  Account[]
}

model Account {
  id                   String        @id @default(uuid())
  accountNumber        Int           @unique
  status               AccountStatus @default(ACTIVE)
  balance              Decimal       @default(0) @db.Decimal(19, 4)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  userId               String
  user                 User          @relation(fields: [userId], references: [id])
  outgoingTransactions Transaction[] @relation("SourceAccount")
  incomingTransactions Transaction[] @relation("DestinationAccount")
}

model Transaction {
  id                   String          @id @default(uuid())
  amount               Decimal         @db.Decimal(19, 4)
  type                 TransactionType
  description          String?
  createdAt            DateTime        @default(now())
  sourceAccountId      String? // nullable - not needed for CREDIT (WIHDRAWAL)
  destinationAccountId String? // nullable — not needed for DEBIT (TOPUP)
  sourceAccount        Account?        @relation("SourceAccount", fields: [sourceAccountId], references: [id], onDelete: Cascade)
  destinationAccount   Account?        @relation("DestinationAccount", fields: [destinationAccountId], references: [id], onDelete: SetNull)
}
